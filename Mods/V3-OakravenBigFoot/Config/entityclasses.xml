<configs>

<append xpath="/entity_classes">

		<!-- *** ZOMBIE_OAK_BIG_FOOT -->	
<entity_class name="zombieOakravenZombieBigFoot" extends="zombieTemplateMale">
	<property name="UserSpawnType" value="Menu"/>
	<property name="Censor" value="1,2"/>
	<property name="Tags" value="entity,zombie,walker,feral"/>
	<property name="Class" value="EntityZombieCop"/>
	<property name="Mesh" value="#@modfolder:Resources/oakravenzombiebigfoot.unity3d?bigfoot.prefab"/>
	<property name="SoundStepType" value="barehvystep"/>
	<property name="SizeScale" value="1"/>
	<property name="ModelType" value="Standard"/>
	<property name="WalkType" value="2"/>
    <property name="PhysicsBody" value="OakConvertedStandard"/>
	<property name="AITask" value="
	BreakBlock|
	ApproachDistraction|
	RangedAttackTarget itemType=1;cooldown=4;duration=3;minRange=1;maxRange=6;unreachableRange=18|
	DestroyArea|
	ApproachAndAttackTarget class=EntityPlayer,0,EntityBandit,0,EntityNPC,0,EntityEnemyAnimal,0,EntityNPC,0|
	ApproachSpot|
	Look|
	Wander|
	"/>

	<property name="SoundRandom" value="zombie_mutated_roam"/>
	<property name="SoundAlert" value="zombie_mutated_alert"/>
	<property name="SoundAttack" value="zombie_mutated_attack"/>
	<property name="SoundHurt" value="zombie_mutated_pain"/>
	<property name="SoundDeath" value="zombie_mutated_death"/>
	<property name="SoundSense" value="zombie_mutated_sense"/>

	<!-- Gameplay zombieMutated -->
	<property name="HandItem" value="meleeHandBigFoot001"/>
	<property name="ExplodeHealthThreshold" value="0"/>
	<property name="MoveSpeed" value=".5"/>
	<property name="MoveSpeedAggro" value="0.6, 1.45"/> <!-- Fit Feral -->
	<property name="PainResistPerHit" value=".9"/><!-- Radiated -->
	<property name="ExperienceGain" value="2000"/>
	<property name="LootDropEntityClass" value="EntityLootContainerBoss"/>
	<property name="LootDropProb" value=".3"/> <!-- Demo -->
	<drop event="Harvest" name="foodRawMeat" count="0" tool_category="Butcher"/>
	<drop event="Harvest" name="foodRottingFlesh" tag="butcherHarvest" count="50"/> <!-- animalZombieBear -->
	<drop event="Harvest" name="resourceLeather" tag="butcherHarvest" count="15"/>
	<drop event="Harvest" name="resourceAnimalFat" tag="butcherHarvest" count="5"/>
	<drop event="Harvest" name="resourceBone" tag="butcherHarvest" count="25"/>
	<drop event="Harvest" name="resourceBone" tag="allToolsHarvest" count="5"/>
	<drop event="Harvest" name="resourceTestosteroneExtract" tag="butcherHarvest" count="2"/>
    <effect_group name="Base Effects">
        <passive_effect name="HealthMax" operation="base_set" value="1500"/>
		<triggered_effect trigger="onOtherDamagedSelf" action="ModifyCVar" target="self" cvar="RadiatedRegenAmount" operation="set" value="2"/>
		<triggered_effect trigger="onOtherDamagedSelf" action="AddBuff" target="self" buff="buffRadiatedRegen"/>
    </effect_group>
</entity_class>	

